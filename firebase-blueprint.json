{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "E-commerce product details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "discountPrice": { "type": "number" },
        "stock": { "type": "integer" },
        "sku": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "categoryId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "isFeatured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug", "price", "stock"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "shipped", "delivered", "cancelled"] },
        "address": { "type": "object" },
        "paymentIntentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupons",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percent", "flat"] },
        "value": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" }
      },
      "required": ["code", "discountType", "value"]
    },
    "Media": {
      "title": "Media",
      "description": "Uploaded media assets",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "size": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["url", "name"]
    },
    "Page": {
      "title": "Page",
      "description": "Custom CMS pages",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "sections": { "type": "array" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "seo": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug"]
    },
    "Menu": {
      "title": "Menu",
      "description": "Navigation menus",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "items": { "type": "array" }
      },
      "required": ["name"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Global app settings",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "object" }
      },
      "required": ["key"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/products/{productId}": { "schema": "Product", "description": "Product catalog" },
    "/categories/{categoryId}": { "schema": "Category", "description": "Product categories" },
    "/orders/{orderId}": { "schema": "Order", "description": "Customer orders" },
    "/coupons/{couponId}": { "schema": "Coupon", "description": "Discount coupons" },
    "/media/{mediaId}": { "schema": "Media", "description": "Media library assets" },
    "/pages/{pageId}": { "schema": "Page", "description": "CMS Pages" },
    "/menus/{menuId}": { "schema": "Menu", "description": "Navigation Menus" },
    "/settings/{settingId}": { "schema": "Setting", "description": "Global Settings" }
  }
}
